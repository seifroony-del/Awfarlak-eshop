<!DOCTYPE html>
<html lang="ar">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Premium 3D Neon Catalog</title>
    <!-- خطوط ذكية واستدعاء الأيقونات -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&family=Tajawal:wght@400;700&display=swap" rel="stylesheet">
    
    <style>
        /* التنسيق الأساسي ونظام الألوان السايبيربرانك */
        :root {
            --bg-canvas: #0a0b10;
            --bg-card: rgba(18, 20, 29, 0.7);
            --neon-pink: #ff2a5f;
            --neon-mint: #00f5d4;
            --text-primary: #ffffff;
            --text-secondary: #94a3b8;
            --glass-border: rgba(255, 255, 255, 0.05);
        }

        * {
            box-sizing: border-box;
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }

        body {
            font-family: 'Plus Jakarta Sans', 'Tajawal', sans-serif;
            background-color: var(--bg-canvas);
            color: var(--text-primary);
            margin: 0;
            padding: 40px 20px;
            min-height: 100vh;
            overflow-x: hidden;
            direction: ltr; /* التزام كامل بنظام التصفح والشبكات اليسار إلى اليمين */
        }

        /* خلفية نيون متحركة في العمق لتعزيز العمق البصري */
        body::before {
            content: '';
            position: absolute;
            top: -10%;
            left: -10%;
            width: 50%;
            height: 60%;
            background: radial-gradient(circle, rgba(255, 42, 95, 0.08) 0%, transparent 70%);
            z-index: -1;
            pointer-events: none;
        }

        body::after {
            content: '';
            position: absolute;
            bottom: -10%;
            right: -10%;
            width: 50%;
            height: 60%;
            background: radial-gradient(circle, rgba(0, 245, 214, 0.06) 0%, transparent 70%);
            z-index: -1;
            pointer-events: none;
        }

        /* الهيدر الاحترافي المتوهج */
        .showcase-header {
            text-align: center;
            max-width: 800px;
            margin: 0 auto 50px auto;
            padding: 30px;
            position: relative;
        }

        .showcase-header h1 {
            font-size: 3rem;
            font-weight: 800;
            margin: 0 0 15px 0;
            letter-spacing: -1px;
            background: linear-gradient(135deg, var(--text-primary) 30%, var(--neon-pink) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px rgba(255, 42, 95, 0.2);
        }

        .showcase-header p {
            color: var(--text-secondary);
            font-size: 1.15rem;
            margin: 0;
            font-weight: 300;
        }

        /* شبكة عرض الكروت ثلاثية الأبعاد الفائقة السرعة */
        .catalog-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 35px;
            max-width: 1300px;
            margin: 0 auto;
            perspective: 1000px; /* تفعيل العمق الفراغي للكروت */
        }

        /* الكارت بتأثير الـ 3D والنيون المتطور */
        .dynamic-card {
            background: var(--bg-card);
            border-radius: 24px;
            border: 1px solid var(--glass-border);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            overflow: hidden;
            position: relative;
            display: flex;
            flex-direction: column;
            transform-style: preserve-3d;
            will-change: transform, box-shadow;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* تأثير النيون المتوهج عند التفاعل وحركات الـ 3D Elevate */
        .dynamic-card:hover {
            transform: translateY(-10px) rotateX(4deg) rotateY(-2deg) scale(1.02);
            border-color: rgba(0, 245, 214, 0.3);
            box-shadow: 0 20px 40px rgba(0, 245, 214, 0.1), 0 0 30px rgba(255, 42, 95, 0.05);
        }

        /* حاوية الصورة الرقمية للتحكم الفاخر بالـ 3D */
        .image-canvas {
            position: relative;
            width: 100%;
            height: 250px;
            overflow: hidden;
            background: #161925;
        }

        .image-canvas img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transform: scale(1);
        }

        .dynamic-card:hover .image-canvas img {
            transform: scale(1.08);
        }

        /* شارة التصنيف المتوهجة نيونيًا */
        .category-badge {
            position: absolute;
            top: 15px;
            left: 15px;
            background: rgba(10, 11, 16, 0.75);
            border: 1px solid var(--neon-mint);
            color: var(--neon-mint);
            padding: 6px 14px;
            border-radius: 30px;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            box-shadow: 0 0 10px rgba(0, 245, 214, 0.2);
            z-index: 2;
        }

        /* تفاصيل ومحتوى الكارت الاستراتيجي */
        .card-details {
            padding: 25px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-details h3 {
            font-size: 1.4rem;
            font-weight: 700;
            margin: 0 0 12px 0;
            color: var(--text-primary);
            letter-spacing: -0.5px;
            text-align: right; /* المحاذاة العربية للمنتجات بالداخل لسهولة القراءة */
        }

        .card-details p {
            font-size: 0.95rem;
            color: var(--text-secondary);
            margin: 0 0 20px 0;
            line-height: 1.6;
            text-align: right;
            flex-grow: 1;
        }

        /* نظام تسعير وتفعيل النيون والميتا */
        .meta-pricing {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--glass-border);
            padding-top: 15px;
            margin-top: auto;
            direction: rtl;
        }

        .price-tag {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--neon-pink);
            text-shadow: 0 0 15px rgba(255, 42, 95, 0.3);
        }

        .currency {
            font-size: 0.85rem;
            font-weight: 400;
            color: var(--text-secondary);
            margin-right: 5px;
        }

        /* الزرار الاحترافي الفوري للطلب الفوري المباشر بلمسة نيون ومؤثرات وميض */
        .neon-order-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            background: linear-gradient(135deg, #00f5d4 0%, #00bfa5 100%);
            color: #050608;
            text-decoration: none;
            padding: 14px;
            border-radius: 14px;
            font-weight: 700;
            font-size: 1.05rem;
            margin-top: 20px;
            box-shadow: 0 4px 15px rgba(0, 245, 214, 0.3);
            cursor: pointer;
            direction: rtl;
        }

        .neon-order-btn:hover {
            box-shadow: 0 0 25px rgba(0, 245, 214, 0.6);
            transform: translateY(-2px);
        }

        /* واجهة تحميل هيكلية فائقة السلسلة (Shimmer Skeleton Loader) */
        .skeleton-loader {
            text-align: center;
            grid-column: 1 / -1;
            padding: 80px;
            color: var(--text-secondary);
            font-size: 1.2rem;
            font-weight: 300;
        }

        .skeleton-loader i {
            color: var(--neon-pink);
            margin-bottom: 15px;
            text-shadow: 0 0 15px var(--neon-pink);
        }
    </style>
</head>
<body>

    <!-- الهيدر الرقمي للماركة السايبيربرانك -->
    <div class="showcase-header">
        <h1>NEXT-GEN POS CATALOG</h1>
        <p>استمتع بتجربة تصفح تفاعلية ثلاثية الأبعاد واطلب منتجاتك فوراً وبسلاسة تامة</p>
    </div>

    <!-- شبكة عرض المنتجات بنظام البيانات الحية الذكي والسريع -->
    <div class="catalog-grid" id="catalog-container">
        <div class="skeleton-loader">
            <i class="fas fa-bolt fa-3x fa-spin"></i>
            <div>جاري الاتصال بقاعدة البيانات ومزامنة لوحة النيون...</div>
        </div>
    </div>

    <script>
        // ==================== لوحة التحكم والربط الديناميكي السريع ====================
        
        // 1. تم وضع رابط الـ Web App المأخوذ من الـ Apps Script هنا بنجاح:
        const sheetWebUrl = "https://script.google.com/macros/s/AKfycby8PaW4rTRez_rd4HM8HsqkPGlUOO22FbFRtubDf4tBdovHb5m7SEJJnnT1a8CQeeS7NA/exec";
        
        // 2. اكتب رقم هاتفك هنا لاستقبال الطلبات الفورية مباشرة (بدون علامة +):
        const phoneNumber = "201000000000"; 

        // ===========================================================================

        async function initializePremiumCatalog() {
            const container = document.getElementById('catalog-container');
            
            try {
                const response = await fetch(sheetWebUrl);
                const products = await response.json();
                
                if (!products || products.length === 0) {
                    container.innerHTML = '<div class="skeleton-loader">لم نجد أي منتجات معروضة بجدول البيانات حالياً.</div>';
                    return;
                }
                
                container.innerHTML = ''; // تصفير واجهة التحميل وبدء الرسم الاحترافي الفوري
                
                products.forEach(product => {
                    const whatsappMessage = `مرحباً، أريد طلب هذا المنتج الفاخر من خلال الكتالوج الذكي:\n\n📦 المنتج: ${product.title}\n💰 السعر: ${product.price} EGP\n\nبرجاء تأكيد الطلب لتجهيز الشحن الفوري الحصري.`;
                    const whatsappUrl = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;
                    
                    const cardHTML = `
                        <div class="dynamic-card">
                            <span class="category-badge">${product.category || 'Premium'}</span>
                            <div class="image-canvas">
                                <img src="${product.image || 'https://via.placeholder.com/400x300/161925/ffffff?text=Product+Image'}" alt="${product.title}" loading="lazy">
                            </div>
                            <div class="card-details">
                                <h3>${product.title}</h3>
                                <p>${product.description || 'وصف حصري ومميز معد ومصمم خصيصاً لاستعراض كفاءة وجودة تفاصيل هذا المنتج الفريد.'}</p>
                                <div class="meta-pricing">
                                    <div class="price-tag">
                                        ${product.price}<span class="currency">EGP</span>
                                    </div>
                                </div>
                                <a href="${whatsappUrl}" target="_blank" class="neon-order-btn">
                                    <i class="fab fa-whatsapp fa-lg"></i> إرسال أمر الشراء الفوري
                                </a>
                            </div>
                        </div>
                    `;
                    container.innerHTML += cardHTML;
                });
                
            } catch (error) {
                console.error("خطأ ربط ومزامنة الـ API بنظام الكتالوج ثلاثي الأبعاد:", error);
                container.innerHTML = '<div class="skeleton-loader" style="color: var(--neon-pink);">فشل الربط التلقائي، يرجى التحقق من كود الـ Web App وصلاحية الرابط (Anyone).</div>';
            }
        }

        // تشغيل المحرك فورا للتصفح فائق السرعة
        if (sheetWebUrl !== "ضع_رابط_الـ_WEB_APP_هنا") {
            initializePremiumCatalog();
        }
    </script>
</body>
</html>
